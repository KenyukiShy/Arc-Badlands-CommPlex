# Arc Badlands CommPlex — Environment Variables
# CONFIRMED VALUES FROM SESSION (April 20, 2026)
# cp .env.example .env && fill remaining REPLACE_WITH_ values

# ── Kill switches (BOTH default ON) ─────────
DRY_RUN=true
VERTEX_STATUS=STUB

# ── Voice Backend ────────────────────────────
# GCP_TWILIO = Google TTS + Twilio (RECOMMENDED — ~$0.015/min)
# BLAND      = Bland.ai (~$0.09/min, ~$2 balance at thia@shy2shy.com)
VOICE_BACKEND=GCP_TWILIO

# ── GCP (CONFIRMED ACTIVE) ───────────────────
GCP_PROJECT_ID=commplex-493805
GCS_BUCKET=commplex-assets-493805
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# ── Phone Numbers (CONFIRMED) ────────────────
# Kenyon direct cell (transfer target)
TRANSFER_NUMBER=7018705235
# Google Voice: (701) 951-8490 — for reference/receiving only
# GOOGLE_VOICE_NUMBER=7019518490

# ── Twilio (CONFIRMED NUMBER) ────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_TOKEN
# Twilio toll-free number confirmed: 1-866-736-2349
TWILIO_PHONE_NUMBER=+18667362349
# Cloud Run webhook URL — fill after: gcloud run deploy commplex-api
TWILIO_WEBHOOK_BASE_URL=REPLACE_WITH_CLOUD_RUN_URL

# ── Bland.ai (thia@shy2shy.com, ~$2 balance) ─
BLAND_API_KEY=org_741899502e615287eae2dcbfe47ff760f1ba25d311b516a7ce2bd28c5417a784fc3bf0e3dc06a623ff3d69
BLAND_FROM_NUMBER=REPLACE_WITH_BLAND_NUMBER

# ── Notifications (ntfy) — CONFIRMED ACTIVE ──
NTFY_SERVER=https://ntfy.sh
# PRIMARY topic — confirmed subscribed, 4 notifications received
NTFY_TOPIC=px10pro-commplex-z7x2-alert-hub
NTFY_TOPIC_OPS=commplex-ops-z7x2
NTFY_TOPIC_DEV=commplex-dev-z7x2
NTFY_TOPIC_EMERGENCY=badlands-panic-z7x2

# ── Email (CONFIRMED: use Gmail primary) ─────
# Primary: kjonesmle@gmail.com via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kjonesmle@gmail.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
# Alt: Purelymail (only if Gmail rate limits)
# SMTP_HOST=smtp.purelymail.com
# SMTP_USER=kjonesmle@purelymail.com

# ── Sluice Engine ────────────────────────────
SLUICE_PRICE_STANDARD=28500
SLUICE_PRICE_AGGRESSIVE=24000
SLUICE_MIN_YEAR=2020

# ── Gemini ───────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY

# ── Database ─────────────────────────────────
DATABASE_URL=sqlite:///./commplex_leads.db
PORT=8080
LOG_LEVEL=INFO

# ── SendGrid (only if Gmail rate limits) ─────
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY

# ── Campaign ─────────────────────────────────
ACTIVE_CAMPAIGN=mkz
